.env
.DS_Store
state.json
state.lock
*.pdf
*.rmdoc
*.zip
# Claude Code — track skills only, ignore CLAUDE.md (dev instructions) and memory/settings
.claude/*
!.claude/skills/
!.claude/skills/*/
!.claude/skills/*/SKILL.md
uv.lock

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
.ruff_cache/
.pytest_cache/
.venv-desktop/

# Test leakage — a test patches config.CONFIG_DIR / OBSIDIAN_VAULT_PATH with
# a MagicMock and lab_notebook.append_entry writes a path built from the
# mock, materializing literal "MagicMock/mock.CONFIG_DIR.__truediv__()/..."
# dirs in CWD. Guard against the leakage ending up in the tree.
MagicMock/
.wrangler/
workers/.wrangler/

# Desktop (Electron)
desktop/node_modules/
desktop/dist/
desktop/restart.sh

# Test runner artifacts
test-results/
